# Python build artifacts
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.eggs/
*.egg-info/

# Test + tool caches
.pytest_cache/
.cache/
.mypy_cache/

# OS metadata
.DS_Store
Thumbs.db

# Privacy-audit blobs are regenerated on demand by tools/audit_context_privacy.py.
# Even after the round-3 redaction fixes, these contain per-run timestamps and
# fingerprints that are noisy in diffs and not useful for reproducibility.
# Exclude them; the audit is the gate, not the artifact.
cases/v2/_incoming/**/privacy_audit.json
cases/**/privacy_audit.json
results/**/privacy_audit.json
reports/*_privacy_audit.md
reports/v2/*_privacy_audit.md

# LLM-summary cache: only the REAL Haiku cache ships (it costs API
# calls to regenerate). Mock and stub caches are deterministic CI
# infrastructure, free to regenerate via:
#   python3 tools/run_llm_summary_baseline.py \
#       --provider mock --method llm-summary-v1-mock
results/cache/llm-summary-v1-mock/
results/cache/llm-summary-v1-stub/
docs/plans/

