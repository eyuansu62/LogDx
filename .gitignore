# Python build artifacts
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.eggs/
*.egg-info/

# Test + tool caches
.pytest_cache/
.cache/
.mypy_cache/

# OS metadata
.DS_Store
Thumbs.db

# Privacy-audit blobs are regenerated on demand by tools/audit_context_privacy.py.
# Even after the round-3 redaction fixes, these contain per-run timestamps and
# fingerprints that are noisy in diffs and not useful for reproducibility.
# Exclude them; the audit is the gate, not the artifact.
cases/v2/_incoming/**/privacy_audit.json
cases/**/privacy_audit.json
results/**/privacy_audit.json
reports/*_privacy_audit.md
reports/v2/*_privacy_audit.md

# LLM-summary cache: only the REAL Haiku cache ships (it costs API
# calls to regenerate). Mock and stub caches are deterministic CI
# infrastructure, free to regenerate via:
#   python3 tools/run_llm_summary_baseline.py \
#       --provider mock --method llm-summary-v1-mock
results/cache/llm-summary-v1-mock/
results/cache/llm-summary-v1-stub/
docs/plans/

# LaTeX build artifacts under reports/paper/. The .tex source and
# committed .pdf are tracked; aux/log/intermediate files are not.
reports/paper/*.aux
reports/paper/*.log
reports/paper/*.bbl
reports/paper/*.blg
reports/paper/*.out
reports/paper/*.toc
reports/paper/*.synctex.gz
reports/paper/*.fls
reports/paper/*.fdb_latexmk
reports/paper/*.zip

# Agent-loop full-trajectory dumps. Auto-saved by tools/run_diagnosis.py
# when invoking an agent shim (real-agent-v1+). ~50-500 KB per case;
# a full sweep is ~100 MB. Not committed to git — uploaded to a
# separate HuggingFace dataset via huggingface/upload_trajectories.sh
# instead. Each file carries full conversation messages (assistant
# text + tool_use blocks + tool_result observations) which can echo
# the raw log content; treat as the same trust tier as raw.log.
results/**/__trajectories/
results/**/__trajectories/**

