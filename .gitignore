# Privacy-audit blobs are regenerated on demand by tools/audit_context_privacy.py.
# Even after the round-3 redaction fixes, these contain per-run timestamps and
# fingerprints that are noisy in diffs and not useful for reproducibility.
# Exclude them; the audit is the gate, not the artifact.
cases/v2/_incoming/**/privacy_audit.json
cases/**/privacy_audit.json
results/**/privacy_audit.json
reports/*_privacy_audit.md
reports/v2/*_privacy_audit.md
