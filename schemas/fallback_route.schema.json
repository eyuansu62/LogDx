{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CILogBench E8 fallback route record (per case × policy)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "case_id",
    "split",
    "policy_name",
    "chosen_method",
    "route_reason"
  ],
  "properties": {
    "case_id": {"type": "string"},
    "split": {"type": "string"},
    "policy_name": {"type": "string"},
    "chosen_method": {
      "enum": ["hybrid", "search_agent", "none"]
    },
    "route_reason": {"type": "string"},
    "hybrid_confidence": {"type": ["number", "null"]},
    "hybrid_category": {"type": ["string", "null"]},
    "hybrid_evidence_count": {"type": ["integer", "null"]},
    "hybrid_evidence_in_context_count": {"type": ["integer", "null"]},
    "hybrid_relevant_files_count": {"type": ["integer", "null"]},
    "hybrid_selected_method": {"type": ["string", "null"]},
    "hybrid_provider_error": {"type": ["string", "null"]},
    "raw_log_line_count": {"type": ["integer", "null"]},
    "search_tool_calls": {"type": ["integer", "null"]},
    "search_provider_error": {"type": ["string", "null"]},
    "search_budget_exhausted": {"type": ["boolean", "null"]},
    "chosen_sv1_1": {"type": ["number", "null"]},
    "hybrid_sv1_1": {"type": ["number", "null"]},
    "search_sv1_1": {"type": ["number", "null"]},
    "chosen_total_tokens": {"type": ["integer", "null"]},
    "chosen_confident_error_v1_1": {"type": ["boolean", "null"]}
  }
}
