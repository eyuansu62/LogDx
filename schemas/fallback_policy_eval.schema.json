{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CILogBench E8 fallback policy evaluation",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "experiment_id",
    "protocol_id",
    "mode",
    "policies"
  ],
  "properties": {
    "experiment_id": {"type": "string"},
    "protocol_id": {"type": "string"},
    "mode": {"const": "analysis_only"},
    "hybrid_diagnoser": {"type": "string"},
    "search_agent": {"type": "string"},
    "splits": {"type": "array", "items": {"type": "string"}},
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "policy_name",
          "deployable",
          "macro_sv1_1",
          "macro_total_tokens",
          "search_invocation_rate"
        ],
        "properties": {
          "policy_name": {"type": "string"},
          "deployable": {"type": "boolean"},
          "macro_sv1_1": {"type": ["number", "null"]},
          "macro_total_tokens": {"type": ["number", "null"]},
          "macro_confident_error_v1_1": {"type": ["number", "null"]},
          "provider_error_rate": {"type": ["number", "null"]},
          "search_invocation_rate": {"type": ["number", "null"]},
          "splits": {"type": "object"},
          "routes": {"type": "array"}
        }
      }
    }
  }
}
