{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CILogBench search-agent diagnosis row (compatible with diagnosis.schema.json)",
  "type": "object",
  "additionalProperties": true,
  "required": ["case_id", "context_method", "diagnoser", "diagnosis", "input", "metadata"],
  "properties": {
    "case_id": {"type": "string"},
    "context_method": {"type": "string"},
    "diagnoser": {"type": "string"},
    "diagnoser_name": {"type": ["string", "null"]},
    "mode": {"const": "root_cause_diagnosis"},
    "diagnosis": {"type": "object"},
    "input": {"type": "object"},
    "metadata": {
      "type": "object",
      "required": ["method_type", "trace_path"],
      "properties": {
        "method_type": {"const": "end_to_end_search_agent"},
        "trace_path": {"type": "string"},
        "tool_call_count": {"type": "integer"},
        "observed_line_count": {"type": "integer"},
        "observation_tokens_estimate": {"type": "integer"},
        "total_agent_tokens_estimate": {"type": "integer"},
        "budget_exhausted": {"type": "boolean"},
        "provider_error": {"type": ["string", "null"]}
      }
    }
  }
}
