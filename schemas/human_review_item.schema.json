{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CILogBench human review item",
  "description": "One reviewable unit. Method identity is hidden in items.jsonl — only blind_method_id appears in reviewer-facing files.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "review_item_id", "batch_id", "case_id", "diagnoser",
    "label_type", "case_packet", "metadata"
  ],
  "properties": {
    "review_item_id": {"type": "string", "minLength": 1},
    "batch_id":       {"type": "string", "minLength": 1},
    "case_id":        {"type": "string", "minLength": 1},
    "diagnoser":      {"type": "string", "minLength": 1},
    "label_type":     {"type": "string", "enum": ["absolute", "pairwise"]},

    "blind_method_id":  {"type": "string", "pattern": "^method_[A-Z]$"},
    "blind_method_id_a":{"type": "string", "pattern": "^method_[A-Z]$"},
    "blind_method_id_b":{"type": "string", "pattern": "^method_[A-Z]$"},

    "case_packet": {
      "type": "object",
      "required": ["repo", "workflow_name", "job_name", "framework",
                   "allowed_ground_truth_summary"],
      "properties": {
        "repo":                          {"type": "string"},
        "workflow_name":                 {"type": "string"},
        "job_name":                      {"type": "string"},
        "framework":                     {"type": "string"},
        "allowed_ground_truth_summary":  {"type": "string"},
        "required_evidence_excerpt":     {"type": "string"}
      }
    },

    "diagnosis": {
      "type": "object",
      "description": "For label_type=absolute: the single diagnosis under review."
    },
    "diagnosis_a": {"type": "object"},
    "diagnosis_b": {"type": "object"},

    "metadata": {
      "type": "object",
      "required": ["created_at", "protocol_id", "hidden_context_method"],
      "properties": {
        "created_at":             {"type": "string"},
        "protocol_id":            {"type": "string"},
        "diagnosis_sha256":       {"type": "string"},
        "diagnosis_sha256_a":     {"type": "string"},
        "diagnosis_sha256_b":     {"type": "string"},
        "hidden_context_method":  {"type": "boolean", "const": true}
      }
    }
  }
}
