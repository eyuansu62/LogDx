{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CILogBench human review label",
  "description": "A single reviewer's score for one review item. One reviewer_<id>.jsonl row per review_item_id.",
  "type": "object",
  "additionalProperties": true,
  "required": ["review_item_id", "reviewer_id", "label_type"],
  "properties": {
    "review_item_id": {"type": "string", "minLength": 1},
    "reviewer_id":    {"type": "string", "minLength": 1},
    "label_type":     {"type": "string", "enum": ["absolute", "pairwise"]},

    "root_cause_correctness":     {"type": "integer", "minimum": 0, "maximum": 4},
    "evidence_support":           {"type": "integer", "minimum": 0, "maximum": 4},
    "localization_quality":       {"type": "integer", "minimum": 0, "maximum": 4},
    "actionability":              {"type": "integer", "minimum": 0, "maximum": 4},
    "hallucination_severity":     {"type": "integer", "minimum": 0, "maximum": 4},
    "abstention_appropriateness": {
      "type": "string",
      "enum": ["correct_abstention", "inappropriate_abstention",
               "not_applicable"]
    },
    "overall_usefulness":         {"type": "integer", "minimum": 0, "maximum": 4},

    "winner":   {"type": "string", "enum": ["A", "B"]},
    "reason":   {"type": "string"},
    "both_bad": {"type": "boolean"},
    "tie":      {"type": "boolean"},
    "insufficient_information": {"type": "boolean"},

    "notes":      {"type": "string"},
    "created_at": {"type": "string"}
  }
}
