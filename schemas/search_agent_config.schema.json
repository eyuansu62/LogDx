{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CILogBench search-agent config",
  "type": "object",
  "additionalProperties": true,
  "required": ["agent_name", "mode", "provider", "prompt_path", "model", "tool_budget", "allowed_tools"],
  "properties": {
    "agent_name": {"type": "string"},
    "mode": {"const": "end_to_end_search_agent"},
    "provider": {"enum": ["command", "mock"]},
    "command_env_var": {"type": "string"},
    "command_override": {"type": ["string", "null"]},
    "prompt_path": {"type": "string"},
    "model": {
      "type": "object",
      "required": ["model_name", "temperature", "max_output_tokens"],
      "properties": {
        "provider_name": {"type": "string"},
        "model_name": {"type": "string"},
        "model_version": {"type": ["string", "null"]},
        "temperature": {"type": "number"},
        "top_p": {"type": "number"},
        "max_output_tokens": {"type": "integer"},
        "json_mode": {"type": "boolean"},
        "tool_use": {"type": ["string", "boolean"]},
        "web_access": {"type": "boolean"}
      }
    },
    "tool_budget": {
      "type": "object",
      "required": ["max_tool_calls", "max_total_observation_tokens"],
      "properties": {
        "max_tool_calls": {"type": "integer", "minimum": 1},
        "max_total_observation_tokens": {"type": "integer", "minimum": 1},
        "max_single_observation_tokens": {"type": "integer", "minimum": 1},
        "max_matches_per_search": {"type": "integer", "minimum": 1},
        "max_ranges_per_get_lines": {"type": "integer", "minimum": 1}
      }
    },
    "allowed_tools": {
      "type": "array",
      "items": {
        "enum": [
          "get_log_metadata",
          "search_log",
          "get_lines",
          "get_tail",
          "get_head",
          "find_error_blocks",
          "list_github_steps"
        ]
      }
    },
    "privacy": {"type": "object"},
    "anti_leakage": {"type": "object"}
  }
}
