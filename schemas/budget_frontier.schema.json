{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CILogBench E4 budget frontier",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "experiment_id",
    "protocol_id",
    "diagnoser",
    "splits",
    "per_method",
    "per_budget",
    "policies"
  ],
  "properties": {
    "experiment_id": {"type": "string"},
    "protocol_id": {"type": "string"},
    "diagnoser": {"type": "string"},
    "splits": {"type": "array", "items": {"type": "string"}},
    "budgets": {"type": "array", "items": {"type": "integer"}},
    "per_method": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "method",
          "macro_sv1_1",
          "macro_final_context_tokens",
          "macro_total_pipeline_tokens",
          "provider_error_rate",
          "abstention_rate",
          "confident_error_rate_v1_1"
        ]
      }
    },
    "per_budget": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["budget_tokens", "best_deployable_method"]
      }
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "policy",
          "macro_sv1_1",
          "macro_final_context_tokens",
          "macro_total_pipeline_tokens"
        ]
      }
    },
    "case_decisions": {"type": "array"}
  }
}
