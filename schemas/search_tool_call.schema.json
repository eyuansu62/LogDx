{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CILogBench search-agent tool-call action",
  "type": "object",
  "oneOf": [
    {
      "required": ["type", "tool", "arguments"],
      "properties": {
        "type": {"const": "tool_call"},
        "tool": {
          "enum": [
            "get_log_metadata",
            "search_log",
            "get_lines",
            "get_tail",
            "get_head",
            "find_error_blocks",
            "list_github_steps"
          ]
        },
        "arguments": {"type": "object"},
        "rationale": {"type": "string"}
      }
    },
    {
      "required": ["type", "diagnosis"],
      "properties": {
        "type": {"const": "final_diagnosis"},
        "diagnosis": {
          "type": "object",
          "required": ["summary", "root_cause_category", "root_cause", "confidence"],
          "properties": {
            "summary": {"type": "string"},
            "root_cause_category": {"type": "string"},
            "root_cause": {"type": "string"},
            "confidence": {"type": "number", "minimum": 0, "maximum": 1},
            "relevant_files": {"type": "array"},
            "relevant_tests": {"type": "array"},
            "evidence": {"type": "array"},
            "suggested_fix": {"type": "string"}
          }
        }
      }
    }
  ]
}
