{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CILogBench human review report",
  "type": "object",
  "additionalProperties": true,
  "required": ["batch_id", "diagnoser", "reviewer_ids", "items", "methods"],
  "properties": {
    "batch_id":      {"type": "string"},
    "diagnoser":     {"type": "string"},
    "reviewer_ids":  {"type": "array", "items": {"type": "string"}},
    "items": {
      "type": "object",
      "properties": {
        "total":          {"type": "integer", "minimum": 0},
        "absolute":       {"type": "integer", "minimum": 0},
        "pairwise":       {"type": "integer", "minimum": 0}
      }
    },
    "methods": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["context_method", "case_count"],
        "properties": {
          "context_method":            {"type": "string"},
          "case_count":                {"type": "integer"},
          "mean_root_cause_correctness":  {"type": ["number", "null"]},
          "mean_evidence_support":        {"type": ["number", "null"]},
          "mean_localization_quality":    {"type": ["number", "null"]},
          "mean_actionability":           {"type": ["number", "null"]},
          "mean_hallucination_severity":  {"type": ["number", "null"]},
          "mean_overall_usefulness":      {"type": ["number", "null"]},
          "pairwise_wins":                {"type": "integer"},
          "pairwise_losses":              {"type": "integer"},
          "pairwise_ties":                {"type": "integer"}
        }
      }
    },
    "correlation_with_deterministic": {"type": "object"},
    "largest_disagreements":          {"type": "array"},
    "reviewer_agreement":             {"type": "object"}
  }
}
