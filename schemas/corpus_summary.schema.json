{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CILogBench corpus summary",
  "description": "Output of tools/summarize_corpus.py — per-split tallies across every tag axis.",
  "type": "object",
  "additionalProperties": true,
  "required": ["splits", "totals"],
  "properties": {
    "generated_at": {"type": "string"},
    "splits": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["case_count"],
        "properties": {
          "case_count":        {"type": "integer", "minimum": 0},
          "framework":         {"type": "object"},
          "failure_category":  {"type": "object"},
          "log_size_bucket":   {"type": "object"},
          "signal_position":   {"type": "object"},
          "evidence_formats":  {"type": "object"},
          "noise_profile":     {"type": "object"},
          "diagnosis_difficulty": {"type": "object"},
          "multi_failure_count":  {"type": "integer"},
          "flaky_or_transient_count": {"type": "integer"}
        }
      }
    },
    "totals": {
      "type": "object",
      "required": ["case_count"],
      "properties": {
        "case_count":        {"type": "integer", "minimum": 0},
        "framework":         {"type": "object"},
        "failure_category":  {"type": "object"},
        "log_size_bucket":   {"type": "object"},
        "signal_position":   {"type": "object"},
        "evidence_formats":  {"type": "object"},
        "noise_profile":     {"type": "object"}
      }
    }
  }
}
