{
  "diagnoser_name": "real-debugger-v1",
  "provider": "command",
  "command_env_var": "DIAGNOSIS_COMMAND",
  "command_override": null,
  "prompt_path": "prompts/debugger_v1.md",

  "model": {
    "provider_name": "anthropic",
    "model_name": "claude-haiku-4-5",
    "model_version": "2026-04-25",
    "temperature": 0,
    "top_p": 1.0,
    "max_output_tokens": 1200,
    "json_mode": true,
    "deterministic": false,
    "tool_use": false,
    "web_access": false
  },

  "context_policy": {
    "allow_raw_context": true,
    "max_context_tokens": null,
    "on_context_too_large": "mark_unsupported",
    "allow_truncation": false
  },

  "privacy": {
    "requires_explicit_external_llm_opt_in": true,
    "redaction_mode": "audit_only",
    "allow_secret_values_in_results": false
  }
}
