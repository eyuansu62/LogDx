{
  "summarizer_name": "claude-haiku-4-5-summary-v1",
  "method_name": "llm-summary-v1-haiku",
  "provider": "command",
  "command_env_var": "LLM_SUMMARY_COMMAND",
  "command_override": null,

  "prompts": {
    "map_prompt_path": "prompts/llm_summary_v1_map.md",
    "reduce_prompt_path": "prompts/llm_summary_v1_reduce.md"
  },

  "model": {
    "provider_name": "anthropic",
    "model_name": "claude-haiku-4-5",
    "model_version": "2026-04-25",
    "temperature": 0,
    "top_p": 1.0,
    "max_output_tokens": 1800,
    "json_mode": false,
    "deterministic": false,
    "tool_use": false,
    "web_access": false
  },

  "chunking": {
    "chunk_tokens": 8000,
    "chunk_overlap_tokens": 400,
    "chunk_lines": 500,
    "chunk_overlap_lines": 25,
    "max_chunks": null,
    "on_context_too_large": "chunk"
  },

  "privacy": {
    "requires_explicit_external_llm_opt_in": true,
    "redaction_mode": "audit_only",
    "allow_secret_values_in_results": false
  }
}
