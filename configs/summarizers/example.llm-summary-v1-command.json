{
  "summarizer_name": "example-summarizer-v1",
  "method_name": "llm-summary-v1-example",
  "provider": "command",
  "command_env_var": "LLM_SUMMARY_COMMAND",
  "command_override": null,

  "prompts": {
    "map_prompt_path": "prompts/llm_summary_v1_map.md",
    "reduce_prompt_path": "prompts/llm_summary_v1_reduce.md"
  },

  "model": {
    "provider_name": "user-configured",
    "model_name": "user-configured-model",
    "model_version": "unknown",
    "temperature": 0,
    "top_p": 1.0,
    "max_output_tokens": 1800,
    "json_mode": false,
    "deterministic": true
  },

  "chunking": {
    "chunk_tokens": 6000,
    "chunk_overlap_tokens": 300,
    "chunk_lines": 400,
    "chunk_overlap_lines": 20,
    "max_chunks": null,
    "on_context_too_large": "chunk"
  },

  "privacy": {
    "requires_explicit_external_llm_opt_in": true,
    "redaction_mode": "audit_only",
    "allow_secret_values_in_results": false
  }
}
