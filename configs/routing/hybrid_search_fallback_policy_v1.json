{
  "config_version": "v1",
  "_doc": [
    "E8 routing-policy declaration. Each policy decides per-case which of",
    "  hybrid (= results/<split>/diagnoses/real-debugger-v2/hybrid-grep-4k-rtk-err-cat-v1)",
    "  search_agent (= results/<split>/diagnoses/mcp-search-agent-v1-sonnet/...)",
    "to attribute as the chosen diagnosis. Each policy can use only the",
    "deployable signals listed in `allowed_route_inputs`. None of these are",
    "scoring data — scoring is computed once per case for both methods and",
    "applied AFTER routing.",
    "",
    "The 'oracle-by-case' policy is included as an upper-bound only and is",
    "explicitly NOT deployable (it reads diagnosis_score_v1_1 to choose).",
    "Every other policy must declare deployable: true."
  ],
  "primary_score": "diagnosis_score_v1_1",
  "secondary_score": "diagnosis_score_v1",
  "hybrid_method_in_protocol": "hybrid-grep-4k-rtk-err-cat-v1",
  "hybrid_diagnoser_default": "real-debugger-v2",
  "search_agent_default": "mcp-search-agent-v1-sonnet",
  "allowed_route_inputs": [
    "hybrid_confidence",
    "hybrid_category",
    "hybrid_root_cause_text",
    "hybrid_evidence_count",
    "hybrid_evidence_in_context_count",
    "hybrid_relevant_files_count",
    "hybrid_relevant_tests_count",
    "hybrid_selected_method",
    "hybrid_context_token_estimate",
    "hybrid_provider_error",
    "raw_log_line_count",
    "raw_log_byte_size",
    "framework",
    "repo",
    "workflow_name",
    "job_name"
  ],
  "forbidden_route_inputs": [
    "ground_truth.*",
    "failure_category",
    "required_signals",
    "evidence_spans",
    "diagnosis_score_v1",
    "diagnosis_score_v1_1",
    "category_match_score_v1_1",
    "critical_signal_mention_recall",
    "must_mention_coverage",
    "valid_evidence_quote_rate",
    "forbidden_claim_violations",
    "review/batches/*"
  ],
  "policies": [
    {
      "policy_name": "hybrid-default",
      "deployable": true,
      "rule": "always_choose_hybrid",
      "_note": "Reproduces E6 hybrid metrics."
    },
    {
      "policy_name": "search-default",
      "deployable": true,
      "rule": "always_choose_search_agent",
      "_note": "Reproduces E7 search-agent metrics."
    },
    {
      "policy_name": "hybrid-if-confident-else-search@0.50",
      "deployable": true,
      "rule": "hybrid_if_confidence_geq",
      "threshold": 0.50
    },
    {
      "policy_name": "hybrid-if-confident-else-search@0.60",
      "deployable": true,
      "rule": "hybrid_if_confidence_geq",
      "threshold": 0.60
    },
    {
      "policy_name": "hybrid-if-confident-else-search@0.70",
      "deployable": true,
      "rule": "hybrid_if_confidence_geq",
      "threshold": 0.70
    },
    {
      "policy_name": "hybrid-if-confident-else-search@0.80",
      "deployable": true,
      "rule": "hybrid_if_confidence_geq",
      "threshold": 0.80
    },
    {
      "policy_name": "hybrid-if-known-else-search",
      "deployable": true,
      "rule": "hybrid_if_known",
      "min_confidence": 0.50
    },
    {
      "policy_name": "hybrid-if-evidence-else-search",
      "deployable": true,
      "rule": "hybrid_if_evidence_in_context",
      "min_evidence_count": 1,
      "min_confidence": 0.50
    },
    {
      "policy_name": "rtk-selected-hybrid-then-search",
      "deployable": true,
      "rule": "hybrid_if_grep_selected"
    },
    {
      "policy_name": "large-log-avoid-search",
      "deployable": true,
      "rule": "large_log_then_hybrid_else_confidence_gate",
      "log_line_threshold": 5000,
      "confidence_threshold": 0.70
    },
    {
      "policy_name": "oracle-by-case",
      "deployable": false,
      "rule": "argmax_sv1_1",
      "_warning": "ORACLE — uses diagnosis_score_v1_1 to choose. Upper bound only."
    }
  ]
}
